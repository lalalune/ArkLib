import ArkLib.Data.CodingTheory.ProximityGap.WBPencilWindowLaw
import ArkLib.Data.CodingTheory.ProximityGap.WBPencilLinearBudget

/-!
# The window capstone: the below-UDR law from the unanchored residual (#371)

The honest factorization after the falsification round
(`probe_wb_window_corank2.py`, `probe_wb_window_anchor_existential.py`,
`probe_wb_window_reduced_anchor.py`):

* `WindowPencilAnchored` is **NOT universal**: class-V stacks (rows that are
  rational-with-exceptions, i.e. every WB representation's denominator vanishes
  somewhere on the domain) generically have pencil corank ‚â• 2 for EVERY
  representation pair (103/130 fresh class-V stacks, full WB-space enumeration),
  and common-factor reduction with shrunken caps rescues only part of the class
  (the survivors: shared reduced denominators / post-reduction polynomial rows).
  DISPROOF_LOG carries the record.

* BUT every probed unanchored stack has at most **2** mca-bad scalars (vs the
  incidence-law counts that anchored stacks can reach).  The structural reason
  (the attack route for the residual): below UDR with `gcd(‚Ñì‚ÇÄ‚Ñì‚ÇÅ, Z_D) = 1`, two
  `F(Œ≥)`-independent kernel solutions force `Q‚ÇÅZ‚ÇÇ = Q‚ÇÇZ‚ÇÅ` (degree < n) and
  `Z_D ‚à£ W` for the cross-difference `W` ‚Äî the kernel is **cyclic**, generated by
  one primitive triple `(g, œÅ, c)` with slack in all three degree caps; a bad
  scalar then needs `g(Œ≥,¬∑)` to split over the domain, which is the same
  incidence count run on the primitive curve.

This file names the residual in its corrected, weakest-known form ‚Äî
`UnanchoredLinear`: doubly-WB-solvable stacks with NO anchored representation
have ‚â§ `n` bad scalars (probe record: ‚â§ 2; budget `n` matches the repaired
linear architecture and is robust to the `n = q‚àí1` probe-blindness lesson of
the normalizer-family refutation) ‚Äî and derives the below-UDR law from it:
`Œµ_mca(RS, Œ¥) ‚â§ ((n+1)(w+1)+1)/q` for every `Œ¥ ‚â§ w/n`, hence at production
shape (`q ‚â• n¬≤¬∑2¬π¬≤‚Å∏`) the Œ¥* floor moves to the unique-decoding radius
`(1‚àíœÅ)/2`.  `UnanchoredLinear` is STRICTLY weaker than the repaired
`WindowRationalLinear` (the implication is `unanchoredLinear_of_windowRationalLinear`):
the anchored bulk of the stack space is now carried by the proven window
pencil law, and only the unanchored exceptional class remains conditional.
-/

open Finset Polynomial
open scoped NNReal ENNReal ProbabilityTheory

set_option linter.unusedSectionVars false

namespace ProximityGap.WBPencil

open ProximityGap.SpikeFloor

variable {F : Type} [Field F] [Fintype F] [DecidableEq F]
variable {n : ‚Ñï} [NeZero n]

open Classical in
/-- **The corrected named residual of the below-UDR law.**  Every
doubly-WB-solvable stack with NO anchored representation pair has at most
`n` mca-bad scalars.  Probe record: every unanchored stack found (class V and
its reductions) has ‚â§ 2 bad scalars; the cyclic-kernel structure of corank-‚â•2
pencils is the identified proof route.  Strictly weaker than the repaired
all-stacks Prop `WindowRationalLinear`. -/
def UnanchoredLinear (dom : Fin n ‚Ü™ F) (k w : ‚Ñï) (Œ¥ : ‚Ñù‚â•0) : Prop :=
  ‚àÄ u‚ÇÄ u‚ÇÅ : Fin n ‚Üí F, WBSolvable dom k w u‚ÇÄ ‚Üí WBSolvable dom k w u‚ÇÅ ‚Üí
    ¬¨ WindowPencilAnchored dom k w u‚ÇÄ u‚ÇÅ ‚Üí
    (Finset.univ.filter (fun Œ≥ : F => mcaEvent (F := F)
      ((rsCode dom k : Submodule F (Fin n ‚Üí F)) : Set (Fin n ‚Üí F)) Œ¥ u‚ÇÄ u‚ÇÅ Œ≥)).card
      ‚â§ n

open Classical in
/-- The corrected residual is strictly weaker than the repaired all-stacks
linear Prop: `WindowRationalLinear` discharges it by forgetting the
non-anchoredness hypothesis. -/
theorem unanchoredLinear_of_windowRationalLinear (dom : Fin n ‚Ü™ F) {k w : ‚Ñï}
    {Œ¥ : ‚Ñù‚â•0} (h : WindowRationalLinear dom k w Œ¥) :
    UnanchoredLinear dom k w Œ¥ :=
  fun u‚ÇÄ u‚ÇÅ h‚ÇÄ h‚ÇÅ _ => h u‚ÇÄ u‚ÇÅ h‚ÇÄ h‚ÇÅ

open Classical in
/-- **THE BELOW-UDR LAW, residual-corrected form**: under `UnanchoredLinear`
alone, every radius `Œ¥ ‚â§ w/n` below the unique-decoding slack has
`Œµ_mca(RS, Œ¥) ‚â§ ((w+1) + n(w+1) + 1)/q` ‚Äî anchored stacks by the window pencil
law, unanchored stacks by the residual (`w+3` is absorbed by the poly budget). -/
theorem epsMCA_le_below_udr_of_unanchoredLinear (dom : Fin n ‚Ü™ F) {k w : ‚Ñï}
    (hk : 1 ‚â§ k) (hwk : w + k ‚â§ n) {Œ¥ : ‚Ñù‚â•0}
    (hŒ¥n : Œ¥ * (Fintype.card (Fin n) : ‚Ñù‚â•0) ‚â§ w)
    (hres : UnanchoredLinear dom k w Œ¥) :
    epsMCA (F := F) (A := F)
        ((rsCode dom k : Submodule F (Fin n ‚Üí F)) : Set (Fin n ‚Üí F)) Œ¥
      ‚â§ (((w + 1) + n * (w + 1) + 1 : ‚Ñï) : ‚Ñù‚â•0‚àû) / (Fintype.card F : ‚Ñù‚â•0‚àû) := by
  have hn1 : 1 ‚â§ n := Nat.one_le_iff_ne_zero.mpr (NeZero.ne n)
  have hnw : w + 1 ‚â§ n * (w + 1) := Nat.le_mul_of_pos_left _ (by omega)
  rw [epsMCA]
  refine iSup_le fun u => ?_
  rw [prob_uniform_eq_card_filter_div_card]
  refine ENNReal.div_le_div_right ?_ _
  by_cases h1 : WBSolvable dom k w (u 1)
  ¬∑ by_cases h0 : WBSolvable dom k w (u 0)
    ¬∑ by_cases hanch : WindowPencilAnchored dom k w (u 0) (u 1)
      ¬∑ -- anchored: the window pencil law
        have := badScalars_card_le_of_windowPencilAnchored dom hk hŒ¥n hanch
        exact_mod_cast this
      ¬∑ -- unanchored: the residual
        have := hres (u 0) (u 1) h0 h1 hanch
        have hb : (Finset.univ.filter (fun Œ≥ : F => mcaEvent (F := F)
            ((rsCode dom k : Submodule F (Fin n ‚Üí F)) : Set (Fin n ‚Üí F)) Œ¥
            (u 0) (u 1) Œ≥)).card ‚â§ (w + 1) + n * (w + 1) + 1 := by
          have hnn : n ‚â§ n * (w + 1) := Nat.le_mul_of_pos_right _ (by omega)
          omega
        exact_mod_cast hb
    ¬∑ -- offset row far: swap + pencil
      have hswap := badScalars_card_swap_le
        (rsCode dom k : Submodule F (Fin n ‚Üí F)) Œ¥ (u 0) (u 1)
      have hfar := badScalars_card_le_of_far_snd dom hk hwk hŒ¥n
        (u‚ÇÄ := u 1) (u‚ÇÅ := u 0) h0
      have hb : (Finset.univ.filter (fun Œ≥ : F => mcaEvent (F := F)
          ((rsCode dom k : Submodule F (Fin n ‚Üí F)) : Set (Fin n ‚Üí F)) Œ¥
          (u 0) (u 1) Œ≥)).card ‚â§ (w + 1) + n * (w + 1) + 1 := by omega
      exact_mod_cast hb
  ¬∑ -- direction row far: the pencil bound directly
    have hfar := badScalars_card_le_of_far_snd dom hk hwk hŒ¥n
      (u‚ÇÄ := u 0) (u‚ÇÅ := u 1) h1
    have hb : (Finset.univ.filter (fun Œ≥ : F => mcaEvent (F := F)
        ((rsCode dom k : Submodule F (Fin n ‚Üí F)) : Set (Fin n ‚Üí F)) Œ¥
        (u 0) (u 1) Œ≥)).card ‚â§ (w + 1) + n * (w + 1) + 1 := by omega
    exact_mod_cast hb

open Classical in
/-- The threshold form: under the corrected residual, the Œ¥* floor clears every
below-UDR radius whose poly(n) budget fits `Œµ*` ‚Äî at production
(`Œµ* = 2^{‚àí128}`, `q ‚â• ((n+1)(w+1)+1)¬∑2^{128}`) the floor is the
unique-decoding radius. -/
theorem le_mcaDeltaStar_below_udr_of_unanchoredLinear (dom : Fin n ‚Ü™ F)
    {k w : ‚Ñï} (hk : 1 ‚â§ k) (hwk : w + k ‚â§ n) {Œ¥ : ‚Ñù‚â•0} (hŒ¥1 : Œ¥ ‚â§ 1)
    (hŒ¥n : Œ¥ * (Fintype.card (Fin n) : ‚Ñù‚â•0) ‚â§ w)
    (hres : UnanchoredLinear dom k w Œ¥)
    {Œµstar : ‚Ñù‚â•0‚àû}
    (hbudget : (((w + 1) + n * (w + 1) + 1 : ‚Ñï) : ‚Ñù‚â•0‚àû) / (Fintype.card F : ‚Ñù‚â•0‚àû)
      ‚â§ Œµstar) :
    Œ¥ ‚â§ ProximityGap.MCAThresholdLedger.mcaDeltaStar (F := F) (A := F)
        ((rsCode dom k : Submodule F (Fin n ‚Üí F)) : Set (Fin n ‚Üí F)) Œµstar :=
  ProximityGap.MCAThresholdLedger.le_mcaDeltaStar_of_good _ _ hŒ¥1
    (le_trans (epsMCA_le_below_udr_of_unanchoredLinear dom hk hwk hŒ¥n hres)
      hbudget)

end ProximityGap.WBPencil

-- Axiom audit (expected: propext, Classical.choice, Quot.sound only)
#print axioms ProximityGap.WBPencil.epsMCA_le_below_udr_of_unanchoredLinear
#print axioms ProximityGap.WBPencil.le_mcaDeltaStar_below_udr_of_unanchoredLinear
